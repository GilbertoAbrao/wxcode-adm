# wxcode-adm Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- App ---
APP_ENV=development
DEBUG=true
BACKEND_PORT=8060

# --- Database ---
# PostgreSQL with asyncpg driver
DATABASE_URL=postgresql+asyncpg://wxcode:wxcode_dev@localhost:5432/wxcode_adm

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT (Phase 2) ---
# RSA private key for signing JWTs (PEM format, multi-line quoted)
JWT_PRIVATE_KEY="<RSA private key PEM>"
# RSA public key for verifying JWTs (shared with wxcode engine)
JWT_PUBLIC_KEY="<RSA public key PEM>"

# --- Super-admin seed ---
SUPER_ADMIN_EMAIL=admin@wxcode.io
SUPER_ADMIN_PASSWORD=changeme

# --- CORS ---
ALLOWED_ORIGINS=["http://localhost:3060"]
